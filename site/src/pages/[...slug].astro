---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToPrev from "@components/BackToPrev.astro";
import { redirects, hostedDemos } from "../links";

export async function getStaticPaths() {
  const [writing, notes] = await Promise.all([
    getCollection("projects-and-writing"),
    getCollection("notes"),
  ]);

  // --- Slug collision check ---
  const slugSources: Record<string, string[]> = {};

  const track = (slug: string, source: string) => {
    (slugSources[slug] ??= []).push(source);
  };

  // Static pages
  for (const page of ["notes", "projects-and-writing", "previously"]) {
    track(page, `static page (${page})`);
  }

  // Redirects
  for (const slug of Object.keys(redirects)) {
    track(slug, `redirect (${slug})`);
  }

  // Hosted demos
  for (const demo of hostedDemos) {
    track(demo.slug, `hosted demo (${demo.slug})`);
  }

  // Content collections
  for (const entry of writing) {
    track(entry.data.slug || entry.slug, `projectsAndWriting/${entry.slug}`);
  }
  for (const entry of notes) {
    if (!entry.data.link) {
      track(entry.data.slug || entry.slug, `notes/${entry.slug}`);
    }
  }

  const collisions = Object.entries(slugSources).filter(([, sources]) => sources.length > 1);
  if (collisions.length > 0) {
    const details = collisions
      .map(([slug, sources]) => `  "${slug}" used by: ${sources.join(", ")}`)
      .join("\n");
    throw new Error(`Slug collisions detected:\n${details}`);
  }

  // --- Build paths ---
  const contentPaths = [
    ...writing.map((entry) => ({
      params: { slug: entry.data.slug || entry.slug },
      props: { entry, collection: "projects-and-writing" as const },
    })),
    ...notes
      .filter((entry) => !entry.data.link)
      .map((entry) => ({
        params: { slug: entry.data.slug || entry.slug },
        props: { entry, collection: "notes" as const },
      })),
  ];

  const redirectPaths = Object.entries(redirects).map(([slug, url]) => ({
    params: { slug },
    props: { entry: null, collection: "redirect" as const, redirectURL: url },
  }));

  return [...contentPaths, ...redirectPaths];
}

const { entry, collection, redirectURL } = Astro.props;
---

{collection === "redirect" ? (
  <html>
    <head>
      <meta charset="utf-8" />
      <meta http-equiv="refresh" content={`0; url=${redirectURL}`} />
      <link rel="canonical" href={redirectURL} />
      <title>Redirecting...</title>
    </head>
    <body>
      <p>Redirecting to <a href={redirectURL}>{redirectURL}</a>...</p>
      <script is:inline define:vars={{ url: redirectURL }}>
        window.location.replace(url);
      </script>
    </body>
  </html>
) : (
  <PageLayout title={entry.data.title} description={entry.data.description}>
    <Container>
      <div class="animate">
        <BackToPrev href={collection === "projects-and-writing" ? "/projects-and-writing" : "/notes"}>
          Back to {collection === "projects-and-writing" ? "projects & writing" : "notes"}
        </BackToPrev>
      </div>
      <div class="space-y-1 my-10">
        <div class="animate text-2xl font-bold text-[#1a1a1a] dark:text-[#fafafa]">
          {entry.data.title}
        </div>
        {entry.data.description && (
          <div class="animate text-sm italic text-[#1a1a1a]/60 dark:text-[#fafafa]/60">
            {entry.data.description}
          </div>
        )}
        <div class="animate text-sm text-[#1a1a1a]/75 dark:text-[#fafafa]/75">
          <FormattedDate date={entry.data.date} />
        </div>
      </div>
      <article class="animate">
        {async () => { const { Content } = await entry.render(); return <Content />; }}
      </article>
    </Container>
  </PageLayout>
)}
